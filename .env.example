CALLSUP_AUDIO_ENGINE_VAULT_API_KEY_REF=vault://secret/data/callsup/audio-engine#api_key
CALLSUP_AUDIO_ENGINE_VAULT_ENCRYPTION_KEY_REF=vault://secret/data/callsup/audio-engine#encryption_key
CALLSUP_AUDIO_ENGINE_ENFORCE_TLS_IN_TRANSIT=true
CALLSUP_AUDIO_ENGINE_ALLOW_INSECURE_HTTP=false
CALLSUP_AUDIO_ENGINE_LOG_LEVEL=INFO
CALLSUP_AUDIO_ENGINE_DATA_DIR=data

# ─── RapidAPI Whisper (speech-to-text-ai.p.rapidapi.com) ──────────────────────
# Get your key at: https://rapidapi.com/api-sports/api/speech-to-text-ai
CALLSUP_AUDIO_ENGINE_RAPIDAPI_WHISPER_KEY=your-rapidapi-key-here
CALLSUP_AUDIO_ENGINE_RAPIDAPI_WHISPER_HOST=speech-to-text-ai.p.rapidapi.com
CALLSUP_AUDIO_ENGINE_RAPIDAPI_WHISPER_LANG=en

